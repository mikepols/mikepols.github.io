@article{tyagiHalideDiffusionMixed2026,
  title = {Halide diffusion in mixed-halide perovskites and heterojunctions},
  author = {Tyagi, Viren and Pols, Mike and Brocks, Geert and Tao, Shuxia},
  journal = {arXiv},
  year = {2026},
  month = jan,
  abstract = {Migration of halide defects guides ion transport in metal halide perovskites and controls the kinetics of halide mixing and phase separation. We study the diffusion of halide vacancies and interstitials in CsPb(I\(_{x}\)Br\(_{1-x}\))\(_{3}\) and CsPbI\(_{3}\)/CsPbBr\(_{3}\) heterojunctions by molecular dynamics simulations using neural network potentials trained on density functional theory calculations. We observe enhanced diffusion of both vacancies and interstitials in the mixed halide compounds compared to the single halide ones, as well as a difference in mobility between Br and I ions in the mixed compound. Diffusion across heterojunctions is governed by the interface structure, where a Br-rich interface blocks migration of vacancies in particular, but an I-rich interface is permeable. },

  abbr={arXiv},
  arxiv={2601.11503},
  selected={false},
}
